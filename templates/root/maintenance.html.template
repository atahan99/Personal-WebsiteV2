<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{MAINT_SITE_TITLE}}</title>
  <link rel="stylesheet" href="./assets/css/style.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>

<body>

  <main>

    <aside class="sidebar active" data-sidebar aria-hidden="true">

      <div class="sidebar-info">

        <figure class="avatar-box">
          <img src="./assets/images/portrait.png" alt="{{MAINT_AVATAR_ALT}}" width="80">
        </figure>

        <div class="info-content">
          <h1 class="name" title="{{MAINT_DISPLAY_NAME}}">{{MAINT_DISPLAY_NAME}}</h1>
          <p class="title">{{MAINT_PROFILE_TITLE}}</p>
        </div>

      </div>

      <div class="sidebar-info_more">
        <div class="separator"></div>
        <ul class="contacts-list">
          <li class="contact-item">
            <div class="icon-box">
              <ion-icon name="construct-outline"></ion-icon>
            </div>
            <div class="contact-info">
              <p class="contact-title">Status</p>
              <p class="contact-link" style="cursor: default;">{{MAINT_STATUS_TEXT}}</p>
            </div>
          </li>
        </ul>
      </div>

    </aside>

    <div class="main-content">

      <article class="about active" data-page="about">

        <header>
          <h2 class="h2 article-title">{{MAINT_ARTICLE_TITLE}}</h2>
        </header>

        <section class="about-text">
          <p>{{MAINT_BODY_1}}</p>
          <p>{{MAINT_BODY_2}}</p>
        </section>

      </article>

    </div>

  </main>

  <script type="module" src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.esm.js"></script>
  <script nomodule src="https://unpkg.com/ionicons@5.5.2/dist/ionicons/ionicons.js"></script>

</body>

</html>
