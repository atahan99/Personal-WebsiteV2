# Reference only — this project does NOT load .env at runtime or in a build step.
# Use this file as a checklist of values you may mirror into HTML by hand
# (e.g. showcase/index.html sidebar, <title>, maintenance copy in index.html).
# Copy to .env locally if you want a private scratchpad (gitignored).

# --- Showcase (sidebar / meta) ---
SITE_TITLE=
DISPLAY_NAME=
PROFILE_TITLE=
PROFILE_IMAGE_ALT=

# Optional contact / social (add matching HTML in showcase/*.html if you use these)
PUBLIC_EMAIL=
PUBLIC_EMAIL_LABEL=
PUBLIC_EMAIL_LINK_TEXT=
LOCATION_LABEL=
LINKEDIN_URL=
GITHUB_PROFILE_URL=

# --- Maintenance landing (root index.html / maintenance.html) ---
MAINT_SITE_TITLE=
MAINT_DISPLAY_NAME=
MAINT_PROFILE_TITLE=
MAINT_AVATAR_ALT=
MAINT_STATUS_TEXT=
MAINT_ARTICLE_TITLE=
MAINT_BODY_1=

# --- Optional future / docs ---
