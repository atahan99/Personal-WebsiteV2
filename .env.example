# Copy to .env and adjust locally. Never commit .env.
# Run `npm install` then `npm run build` to regenerate HTML from templates/.

# Showcase (sidebar + titles)
SITE_TITLE=
DISPLAY_NAME=
PROFILE_TITLE=
PROFILE_IMAGE_ALT=

# Optional contact (blocks omitted when empty)
PUBLIC_EMAIL=
PUBLIC_EMAIL_VISIBLE=
PUBLIC_EMAIL_LABEL=
LOCATION_LABEL=

# Optional social (list items omitted when empty)
LINKEDIN_URL=
GITHUB_PROFILE_URL=

# Reserved / documentation-only (not substituted by build.mjs yet — edit templates if needed)
HOMELAB_REPO_URL=
TRYHACKME_PROFILE_URL=
SITE_CANONICAL_ORIGIN=
ABOUT_HTML=

# Maintenance landing (root index.html + maintenance.html)
MAINT_SITE_TITLE=
MAINT_DISPLAY_NAME=
MAINT_PROFILE_TITLE=
MAINT_AVATAR_ALT=
MAINT_STATUS_TEXT=
MAINT_ARTICLE_TITLE=
MAINT_BODY_1=
